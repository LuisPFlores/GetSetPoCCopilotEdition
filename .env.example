# ---------------------------------------------------------------------------
# GetSetPOx MCP Server — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ---------------------------------------------------------------------------

# ── Microsoft Graph (required) ──────────────────────────────────────────────
# Azure AD app registration with the Graph application permissions listed
# in README.md § Prerequisites.

MS_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MS_GRAPH_CLIENT_SECRET=your-client-secret-here
MS_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000

# ── MCP server — transport & logging (optional) ─────────────────────────────

# Logging level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
MCP_LOG_LEVEL=INFO

# HTTP transport bind address (used by main_http.py only)
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080